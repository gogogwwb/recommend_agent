# ============================================
# 保险智能推荐Agent系统 - 环境变量配置模板
# ============================================

# -------------------- LLM配置 --------------------
# OpenAI API配置（或兼容接口）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Embedding模型配置
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=768

# -------------------- 数据库配置 --------------------
# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insurance_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# FAISS配置
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIMENSION=768
FAISS_INDEX_TYPE=IndexFlatIP

# -------------------- 应用配置 --------------------
# FastAPI配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
APP_LOG_LEVEL=info

# 会话配置
SESSION_TIMEOUT_DAYS=7
MAX_CONVERSATION_TURNS=15
HOT_DATA_RETENTION_TURNS=5

# -------------------- Agent配置 --------------------
# Profile Collection Agent
PROFILE_AGENT_TIMEOUT=10
PROFILE_AGENT_MAX_RETRIES=3

# Recommendation Agent
RECOMMENDATION_AGENT_TIMEOUT=15
RECOMMENDATION_TOP_K=5
RECOMMENDATION_DIVERSITY_THRESHOLD=0.3

# Compliance Agent
COMPLIANCE_AGENT_TIMEOUT=5
COMPLIANCE_CHECK_ENABLED=true

# -------------------- 性能优化配置 --------------------
# Token压缩
ENABLE_TOKEN_COMPRESSION=true
MAX_TOKENS_PER_SESSION=6000
CONTEXT_COMPRESSION_RATIO=0.5

# 缓存配置
ENABLE_RECOMMENDATION_CACHE=true
CACHE_TTL_SECONDS=3600

# -------------------- 监控和日志配置 --------------------
# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# 性能监控
ENABLE_PERFORMANCE_MONITORING=true
METRICS_EXPORT_INTERVAL=60

# 质量监控
ENABLE_QUALITY_MONITORING=true
QUALITY_THRESHOLD_INTENT_ACCURACY=0.85
QUALITY_THRESHOLD_SLOT_FILL_RATE=0.90

# -------------------- MCP服务器配置 --------------------
# Product Database MCP
PRODUCT_DB_MCP_HOST=localhost
PRODUCT_DB_MCP_PORT=8001

# User Profile MCP
USER_PROFILE_MCP_HOST=localhost
USER_PROFILE_MCP_PORT=8002

# Compliance Rules MCP
COMPLIANCE_MCP_HOST=localhost
COMPLIANCE_MCP_PORT=8003

# Financial Calculator MCP
FINANCIAL_MCP_HOST=localhost
FINANCIAL_MCP_PORT=8004

# -------------------- 安全配置 --------------------
# 数据加密
ENABLE_ENCRYPTION=true
ENCRYPTION_KEY=your_encryption_key_here_32_bytes

# 审计日志
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=./logs/audit.log

# -------------------- 开发配置 --------------------
# 开发模式
DEBUG=false
TESTING=false

# 测试数据库（用于测试）
TEST_POSTGRES_DB=insurance_agent_test
TEST_REDIS_DB=1
